{
{
  "env": { "node": true, "jest": true, "es2021": true },
  "extends": ["eslint:recommended", "prettier"],
  "parserOptions": { "ecmaVersion": "latest", "sourceType": "module" },
  "rules": {
    "semi": ["error", "always"],
    "no-unused-vars": "warn",
    "no-console": "warn",
    "eqeqeq": "error",
    "curly": "error",
    "no-trailing-spaces": "error",
    "no-var": "error",
    "prefer-const": "error"
  }
}